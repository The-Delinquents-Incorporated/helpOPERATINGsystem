# HelpOS defaults — safe for local/offline development.
# Copy these values into backend/.env if you prefer backend-scoped overrides.

API_TITLE=HelpOS API
API_VERSION=0.3.0
RELEASE_CODENAME=Catalyst

# Local Ollama daemon only. Do not point this at an Ollama cloud/proxy endpoint.
OLLAMA_HOST=http://localhost:11434

# HelpOS refuses to call models that are not installed locally and returned by /api/tags.
# Install the default with: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_REQUIRE_LOCAL_MODEL=true

ALLOWED_ORIGINS=["*"]
